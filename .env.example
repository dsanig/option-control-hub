# Frontend
# Optional. Prefer leaving empty so the frontend uses same-origin /api routes.
# Only set this if you intentionally deploy the API on a different origin.
VITE_API_BASE_URL=
# Optional Vite dev proxy target for /api requests
VITE_API_PROXY_TARGET=http://127.0.0.1:3001

# API server
# PORT is preferred; API_PORT remains supported for backward compatibility.
PORT=3001
API_PORT=3001
# Optional, only needed for explicit cross-origin browser calls.
ALLOWED_ORIGINS=

# PostgreSQL connection (preferred)
DATABASE_URL=postgresql://app_user:change_me@postgres:5432/option_control_hub

# PostgreSQL connection (alternative to DATABASE_URL)
# PGHOST=postgres
# PGPORT=5432
# PGUSER=app_user
# PGPASSWORD=change_me
# PGDATABASE=option_control_hub

# SSL controls
# DB_SSL=true enables ssl with rejectUnauthorized=false
# PGSSLMODE can be disable|require
DB_SSL=false
PGSSLMODE=disable

# Pool tuning
PGPOOL_MAX=10
PGPOOL_IDLE_TIMEOUT_MS=30000
PGPOOL_CONNECTION_TIMEOUT_MS=10000

# Portfolio query table location
PORTFOLIO_SCHEMA=public
PORTFOLIO_TABLE=portfolio_positions
